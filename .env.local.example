# Supabase — find in Supabase dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret — Supabase dashboard → Settings → API → JWT Settings → JWT Secret
# This must match exactly what Supabase uses to verify JWTs.
SUPABASE_JWT_SECRET=

# Privy — find in Privy dashboard → App Settings
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
